msgstr "Einstellungen speichern"

msgid "Search"
msgstr "Suchen"

msgid "Search feedback, email, location…"
msgstr "Feedback, E-Mail, Standort suchen…"

msgid "Search location name, slug, address…"
msgstr "Standortname, Slug, Adresse suchen…"

msgid "Search name, email, phone…"
msgstr "Name, E-Mail, Telefonnummer suchen…"

